<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <title>Textora — <%= title %>
    </title>
    <link rel="stylesheet" href="/writeNote.css">
</head>

<body>
    <div class="page-container">
        <div class="note-shell">
            <div class="note-header">
                <h1>
                    <%= title %>
                </h1>

                <a href="/" class="back-link">← Home</a>

            </div>
            <main class="editor-frame">
                <div id="save-status" class="status-idle"></div>
                <textarea class="details" id="note-content" placeholder="Write your note here..."><%= data %></textarea>
            </main>
        </div>

        <aside class="ad-card">
            <button class="ad-nav ad-nav-prev" aria-label="Previous ad">❮</button>
            <div class="ad-carousel" id="adCarousel">
                <div class="ad-item">
                    <img src="/src/saniova.png" alt="Saniova Blog" class="ad-image">
                    <div class="ad-content">
                        <span class="ad-tag">Sponsored</span>
                        <h3>Visit Saniova</h3>
                        <p>Discover amazing blogs and tutorials.</p>
                        <div class="ad-click">
                        <a href="https://saniova.com" class="ad-link" target="_blank"
                            rel="noopener noreferrer">Explore</a>
                        </div>
                    </div>
                </div>
                <div class="ad-item">
                    <img src="/src/saniova2.jpg" alt="Saniova Insights" class="ad-image">
                    <div class="ad-content">
                        <span class="ad-tag">Featured</span>
                        <h3>Saniova Insights</h3>
                        <p>Get the latest coding tips.</p>
                        <div class="ad-click">
                            <a href="https://saniova.com/insights" class="ad-link" target="_blank"
                            rel="noopener noreferrer">Learn More</a>
                        </div>
                    </div>
                </div>
                <div class="ad-item">
                    <img src="/src/saniova3.jpg" alt="Saniova Tutorials" class="ad-image">
                    <div class="ad-content">
                        <span class="ad-tag">New</span>
                        <h3>Saniova Tutorials</h3>
                        <p>Step-by-step developer guides.</p>
                        <div class="ad-click">
                        <a href="https://saniova.com/tutorials" class="ad-link" target="_blank"
                            rel="noopener noreferrer">Start Now</a>
                        </div>
                    </div>
                </div>
            </div>
            <button class="ad-nav ad-nav-next" aria-label="Next ad">❯</button>
            <div class="ad-dots">
                <span class="ad-dot active" data-index="0"></span>
                <span class="ad-dot" data-index="1"></span>
                <span class="ad-dot" data-index="2"></span>
            </div>
        </aside>
    </div>
    <script>const noteTitle = "<%= title %>";</script>
    <script src="/writeNote.js"></script>
</body>

</html>